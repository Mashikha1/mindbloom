# ================================
# MindBloom Backend — Environment
# ================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/mindbloom
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/mindbloom

# JWT Secret — make this a long random string
# Generate one at: https://randomkeygen.com
JWT_SECRET=your_super_secret_jwt_key_make_it_long_and_random_123!
JWT_EXPIRES_IN=7d

# Groq API Key (for Llama AI features)
# Get one for free at: https://console.groq.com/
GROQ_API_KEY=gsk_your_key_here

# OpenAI API Key
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
